# Downloaded provider binaries — not committed (regenerated by terraform init)
.terraform/

# State files — contain resource IDs and may contain sensitive values
terraform.tfstate
terraform.tfstate.backup

# Local variable values — copy terraform.tfvars.example and fill in your values
terraform.tfvars

# Plan files
*.tfplan

# .terraform.lock.hcl is intentionally committed (pins provider versions like package-lock.json)
